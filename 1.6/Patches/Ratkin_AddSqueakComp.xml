<?xml version="1.0" encoding="utf-8"?>
<!--
  把发声组件挂到 Ratkin 种族上,并配置:
    actions  - 各动作触发模式/间隔/概率(数据驱动)
    moodMods - 心情→音色调制参数(运行时作用于 pitchFactor/volumeFactor)
  调行为/心情音色只需改本文件,无需重编译 DLL。
-->
<Patch>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/AlienRace.ThingDef_AlienRace[defName="Ratkin"]/comps</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/AlienRace.ThingDef_AlienRace[defName="Ratkin"]</xpath>
      <value>
        <comps />
      </value>
    </nomatch>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/AlienRace.ThingDef_AlienRace[defName="Ratkin"]/comps</xpath>
    <value>
      <li Class="SqueakyRatkin.CompProperties_Squeaker">
        <globalMinIntervalTicks>180</globalMinIntervalTicks>
        <actions>
          <li><action>Eat</action>     <mode>EachTime</mode>        <minIntervalTicks>120</minIntervalTicks></li>
          <li><action>Call</action>    <mode>RandomOneShot</mode>   <minIntervalTicks>720</minIntervalTicks> <probabilityPerCheck>0.012</probabilityPerCheck></li>
          <li><action>Move</action>    <mode>RandomOneShot</mode>   <minIntervalTicks>420</minIntervalTicks> <probabilityPerCheck>0.012</probabilityPerCheck></li>
          <li><action>Sleep</action>   <mode>RandomOneShot</mode>   <minIntervalTicks>900</minIntervalTicks> <probabilityPerCheck>0.008</probabilityPerCheck></li>
          <li><action>Social</action>  <mode>RandomOneShot</mode>   <minIntervalTicks>420</minIntervalTicks> <probabilityPerCheck>0.016</probabilityPerCheck></li>
          <li><action>Joy</action>     <mode>RandomOneShot</mode>   <minIntervalTicks>420</minIntervalTicks> <probabilityPerCheck>0.016</probabilityPerCheck></li>
          <li><action>Wounded</action> <mode>External</mode>        <minIntervalTicks>180</minIntervalTicks></li>
          <li><action>Select</action>  <mode>External</mode>        <minIntervalTicks>15</minIntervalTicks>   <ignoreGlobalCooldown>true</ignoreGlobalCooldown> <cooldownClock>Realtime</cooldownClock></li>
          <li><action>Death</action>   <mode>External</mode>        <minIntervalTicks>0</minIntervalTicks>   <ignoreGlobalCooldown>true</ignoreGlobalCooldown></li>
        </actions>
        <moodMods>
          <li><mood>Good</mood>    <pitchFactor>1.2</pitchFactor>  <pitchJitter>0.97~1.03</pitchJitter> <volumeFactor>1.3</volumeFactor></li>
          <li><mood>Neutral</mood> <pitchFactor>1.0</pitchFactor>  <pitchJitter>0.97~1.03</pitchJitter> <volumeFactor>1.0</volumeFactor></li>
          <li><mood>Bad</mood>     <pitchFactor>0.8</pitchFactor>   <pitchJitter>0.97~1.03</pitchJitter> <volumeFactor>0.7</volumeFactor></li>
          <li><mood>Break</mood>   <pitchFactor>1.1</pitchFactor>   <pitchJitter>0.6~1.5</pitchJitter>    <volumeFactor>1.5</volumeFactor></li>
        </moodMods>
        <distancePresets>
          <li><preset>Conservative</preset> <range>15~65</range></li>
          <li><preset>Balanced</preset>     <range>15~50</range></li>
          <li><preset>Strong</preset>       <range>15~40</range></li>
        </distancePresets>
      </li>
    </value>
  </Operation>

</Patch>
