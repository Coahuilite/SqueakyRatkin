<!--
  Squeaky Ratkin(鼠辈啁啾) SoundDef —— 每动作 1 个(中性基准),心情靠运行时 pitchFactor/volumeFactor 调制(见 CompSqueaker + moodMods)。
  两套: SR_<Action>(混合:豚鼠default+自定义override共存) / SR_<Action>_Pure(纯自定义override)。
  开关 CompSqueaker.UseCustomOnly: ON 用 _Pure, OFF 用混合。
  default: 原版啮齿类豚鼠(GuineaPig)。自定义音频就位后取消 override 注释 / 改 _Pure grain。
  自定义音频约定: 放 1.6/Sounds/Squeak/<Action>/, 文件名 SR_<Action>_<n>.wav, 单声道。
  pitchRange 用中性(0.95,1.05), 容许 SoundDef 层基础随机; 心情调制由运行时 pitchFactor 叠加。
-->
<Defs>
  <SoundDef><defName>SR_Call</defName><context>MapOnly</context><subSounds><li><grains><li Class="AudioGrain_Folder"><clipFolderPath>Pawn/Animal/GuineaPig/Call</clipFolderPath></li><!-- override 自定义(放 SR_Call_*.wav): <li Class="AudioGrain_Folder"><clipFolderPath>Squeak/Call</clipFolderPath></li> --></grains><volumeRange>(45,55)</volumeRange><pitchRange>(0.95,1.05)</pitchRange><distRange>(15,70)</distRange></li></subSounds></SoundDef>
  <SoundDef><defName>SR_Call_Pure</defName><context>MapOnly</context><subSounds><li><grains><!-- 朋友收集后改为纯自定义 Squeak/Call: <li Class="AudioGrain_Folder"><clipFolderPath>Squeak/Call</clipFolderPath></li> --><li Class="AudioGrain_Folder"><clipFolderPath>Pawn/Animal/GuineaPig/Call</clipFolderPath></li></grains><volumeRange>(45,55)</volumeRange><pitchRange>(0.95,1.05)</pitchRange><distRange>(15,70)</distRange></li></subSounds></SoundDef>
